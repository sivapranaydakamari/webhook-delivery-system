# ─────────────────────────────────────────────────────────────────────────────
# Webhook Delivery System – Environment Variables
# Copy this file to .env and adjust values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Dispatcher ───────────────────────────────────────────────────────────────
# Which backpressure strategy to use.
# Options: rate_limiting | admission_control | load_shedding
BACKPRESSURE_STRATEGY=rate_limiting

# Token bucket settings (used when BACKPRESSURE_STRATEGY=rate_limiting)
TOKEN_BUCKET_CAPACITY=10      # Max tokens each subscriber bucket can hold
TOKEN_REFILL_RATE=2           # Tokens added per second

# Admission control settings (used when BACKPRESSURE_STRATEGY=admission_control)
HIGH_WATER_MARK=100           # Pause reading stream when any queue exceeds this
LOW_WATER_MARK=50             # Resume reading stream when all queues drop below this

# Load shedding settings (used when BACKPRESSURE_STRATEGY=load_shedding)
SHEDDING_FAILURE_THRESHOLD=3  # Consecutive 5xx failures before entering shedding mode

# General dispatcher settings
MAX_RETRIES=3                 # Number of delivery attempts per event

# ── Subscriber Simulator ─────────────────────────────────────────────────────
ADMIN_API_URL=http://admin:8002
SELF_URL=http://subscriber:8000/webhook
RESPONSE_LATENCY_MS=20        # Artificial delay before responding (ms)
ERROR_RATE=0.0                # Fraction of requests to intentionally fail (0.0–1.0)
TIMESTAMP_TOLERANCE_SECONDS=300  # Max age of X-Webhook-Timestamp before rejecting (seconds)
